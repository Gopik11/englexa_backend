{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "builder": "tsc",
    "assets": [
      {
        "include": "grammar-practice/content/**/*.json",
        "outDir": "dist"
      },
      {
        "include": "vocabulary-practice/content/**/*.json",
        "outDir": "dist"
      },
      {
        "include": "reading-practice/content/**/*.json",
        "outDir": "dist"
      },
      {
        "include": "writing-practice/content/**/*.json",
        "outDir": "dist"
      },
      {
        "include": "speaking-practice/content/**/*.json",
        "outDir": "dist"
      }
    ]
  }
}
