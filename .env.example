# Server
PORT=3000
NODE_ENV=development

# Database
# Docker: postgresql://postgres:postgres@localhost:5433/englexa?schema=public
# Local PostgreSQL 17 example (URL-encode special chars in password):
DATABASE_URL="postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@localhost:5432/englexa?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# AI rate limits (per user per day)
AI_FREE_TUTOR_DAILY_LIMIT=5
AI_PREMIUM_TUTOR_DAILY_LIMIT=20
AI_FREE_PRONUNCIATION_DAILY_LIMIT=3
AI_PREMIUM_PRONUNCIATION_DAILY_LIMIT=10
