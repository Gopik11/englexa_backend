# Server
PORT=3000
NODE_ENV=development

# Database
# Docker Compose (backend container -> postgres service):
# DATABASE_URL="postgresql://englexa_user:PassLexa@postgres:5432/englexa?schema=public"
# Host machine via published port 5433:
# DATABASE_URL="postgresql://englexa_user:PassLexa@localhost:5433/englexa?schema=public"
DATABASE_URL="postgresql://englexa_user:PassLexa@localhost:5432/englexa?schema=public"

# JWT (minimum 32 characters each)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# Redis / background jobs (optional — in-memory fallback when Redis is disabled)
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=false
JOBS_ENABLED=true

# AI (required for Spoken English, vocabulary AI, grammar pipeline)
OPENAI_API_KEY=
# Optional alias for speech endpoints (falls back to OPENAI_API_KEY)
SPEECH_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
AI_FREE_TUTOR_DAILY_LIMIT=5
AI_PREMIUM_TUTOR_DAILY_LIMIT=20
AI_FREE_PRONUNCIATION_DAILY_LIMIT=3
AI_PREMIUM_PRONUNCIATION_DAILY_LIMIT=10
