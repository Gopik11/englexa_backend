  {"id":"int_prep_04","level":"intermediate","topic":"prepositions","type":"rewrite","question":"Rewrite: \"We arrived to the airport late.\"","options":null,"correct_answer":"We arrived at the airport late.","explanation":"Use \"arrive at\" for specific places."},
