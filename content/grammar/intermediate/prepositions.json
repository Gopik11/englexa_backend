[
  {"id":"int_prep_01","level":"intermediate","topic":"prepositions","type":"mcq","question":"Choose: \"The meeting is ___ March 5.\"","options":["in","on","at"],"correct_answer":"on","explanation":"Use \"on\" for days and dates."},
